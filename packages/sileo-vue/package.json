{
  "name": "sileo-vue",
  "version": "0.1.0",
  "description": "Physics-based toast notifications for Vue 3 — a Vue port of sileo by aaryan.design",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "vite build && cp src/styles.css dist/styles.css",
    "type-check": "vue-tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "vue": ">=3.3"
  },
  "dependencies": {
    "motion": "^12.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "^5.5.0",
    "vite": "^6.3.2",
    "vite-plugin-dts": "^4.5.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.10"
  },
  "keywords": ["vue", "toast", "notification", "sileo", "spring", "animation", "gooey"],
  "license": "MIT",
  "sideEffects": ["*.css"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TODO/sileo-vue.git",
    "directory": "packages/sileo-vue"
  },
  "homepage": "https://github.com/TODO/sileo-vue#readme",
  "author": "TODO"
}
